# MockMate AI — Backend Environment Variables
# Copy of .env.example with placeholder values
# Replace with your actual values before running

# MongoDB Local (active)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=mockmate

# MongoDB Atlas (uncomment to switch to cloud)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# JWT Auth
JWT_SECRET=mockmate-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Gemini API (add your key when ready)
GEMINI_API_KEY=AIzaSyCc2PFC_dZXVE1Lrd0StkITb2LJa0Ne2Wc

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
